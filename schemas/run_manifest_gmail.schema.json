{
  "name": "run_manifest.tsv",
  "lane": "gmail",
  "kind": "tabular_schema",
  "description": "Per-target execution log for gmail extraction runs.",
  "columns": [
    { "name": "line_no", "type": "integer", "required": true },
    { "name": "slug", "type": "string", "required": true },
    { "name": "mode", "type": "string", "required": true, "enum": ["auto", "inline"] },
    { "name": "status", "type": "string", "required": true, "enum": ["ok", "extract_fail"] },
    { "name": "extracted_count", "type": "integer", "required": true },
    { "name": "ocr_status", "type": "string", "required": true, "enum": ["ok", "not_applicable", "missing_dependency", "fail", "partial", "unknown"] },
    { "name": "pdf_text_status", "type": "string", "required": true, "enum": ["ok", "not_applicable", "missing_dependency", "needs_password_hint", "fail", "partial", "unknown"] },
    { "name": "enrichment_status", "type": "string", "required": true, "enum": ["ok", "not_applicable", "missing_dependency", "needs_password_hint", "fail", "partial", "unknown", "blocked_by_extract_fail"] },
    { "name": "raw_dir", "type": "absolute_path", "required": true },
    { "name": "ocr_manifest", "type": "absolute_path_or_dash", "required": true },
    { "name": "pdf_text_manifest", "type": "absolute_path_or_dash", "required": true },
    { "name": "json_log", "type": "absolute_path", "required": true },
    { "name": "stderr_log", "type": "absolute_path", "required": true },
    { "name": "query", "type": "string", "required": true },
    { "name": "needle", "type": "string", "required": true }
  ]
}
