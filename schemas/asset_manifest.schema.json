{
  "name": "asset_manifest.tsv",
  "kind": "tabular_schema",
  "description": "Per-file metadata truth layer emitted after extraction and OCR.",
  "columns": [
    { "name": "raw_file", "type": "absolute_path", "required": true },
    { "name": "final_file", "type": "absolute_path_or_dash", "required": true },
    { "name": "analysis_date", "type": "date", "format": "YYYY-MM-DD", "required": true },
    { "name": "analysis_date_source", "type": "string", "required": true, "enum": ["provider_page", "gmail_received_or_thread", "artifact_contextual_date", "filename", "run_fallback"] },
    { "name": "analysis_date_status", "type": "string", "required": true, "enum": ["direct", "inferred", "fallback"] },
    { "name": "owner_name", "type": "string", "required": true },
    { "name": "owner_source", "type": "string", "required": true, "enum": ["provider_client", "thread_salutation", "thread_title", "filename_or_text_name", "filename_name", "none"] },
    { "name": "owner_status", "type": "string", "required": true, "enum": ["likely_owner", "weak_owner", "unknown_owner"] },
    { "name": "provider", "type": "string", "required": true },
    { "name": "provider_source", "type": "string", "required": true, "enum": ["thread_provider_hint", "query_domain", "provider_page_text", "thread_text", "none"] },
    { "name": "confidence", "type": "string", "required": true, "enum": ["high", "medium", "low"] },
    { "name": "status", "type": "string", "required": true, "enum": ["ok", "missing_raw", "non_result", "sidecar", "needs_review"] }
  ]
}
